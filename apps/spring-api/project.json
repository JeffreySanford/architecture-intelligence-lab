{
  "name": "spring-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/spring-api/src/main/java",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose build spring-api"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up --build spring-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose run --rm spring-api ./mvnw -pl apps/spring-api test"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose run --rm spring-api ./mvnw -pl apps/spring-api validate"
      }
    }
  },
  "tags": []
}

